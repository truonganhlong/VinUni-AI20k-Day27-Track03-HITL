# OpenAI LLM provider
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# Optional: only set this for an OpenAI-compatible proxy.
# OPENAI_BASE_URL=

# SQLite database path (optional - defaults to ./hitl_audit.db in CWD)
# HITL_DB_PATH=hitl_audit.db

# GitHub Personal Access Token - REQUIRED.
#
# The agent calls the GitHub REST API directly. Generate a token at:
#   https://github.com/settings/tokens/new
# Scopes: tick `public_repo` (enough for VinUni-AI20k/PR-Demo - it's a public repo).
#
# Posting a top-level PR comment works for any authenticated user on a public repo.
# Formal reviews (Approve/Request-changes) would need collaborator status on the target.
GITHUB_TOKEN=

# Optional: shown in audit rows for human approval/escalation steps.
GITHUB_USER=
